<% layout('layouts/boilerplate') %>
<body>
    <div class="row" >
        <div class="col-8 offset-2">
    <h4 class="mt-3">Edit Listing</h4>
    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" novalidate class="needs-validation">
        <div class="mb-3">
        <label for="title" class="form-label">Title:</label>
        <input type="text" name="title" id="title" value="<%= listing.title %>" class="form-control" required><br>
        </div>
        <div class="mb-3">
        <label for="description" class="form-label">Description:</label>
        <textarea name="description" id="description" class="form-control" required><%= listing.description %></textarea><br>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image:</label>
            <input type="file" name="image" id="image" class="form-control" required<%= listing.image ? 'value="' + listing.image + '"' : '' %>><br>
        </div>
        <div class="row">
        <div class="col4 col-md-4">
        <label for="price" class="form-label">Price:</label>
        <input type="number" name="price" id="price" value="<%= listing.price %>" class="form-control" required><br>
        </div>
        <div class="col8 col-md-8">
        <label for="country" class="form-label">Country:</label>
        <input type="text" name="country" id="country" value="<%= listing.country %>" class="form-control" required><br>
        </div>
        </div>
        <div class="mb-3">
        <label for="location" class="form-label">Location:</label>
        <input type="text" name="location" id="location" value="<%= listing.location %>" class="form-control" required><br>
        </div>
        
        <button type="submit" class="add-btn mt-3">Update Listing</button>
    </form>
    </div>
    </div>
</body>
