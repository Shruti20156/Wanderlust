<% layout('layouts/boilerplate') %>
<body>
    <h3>Listing Details</h3>
    <ul>
        <li>Title: <%= listing.title %></li>
        <li>Description: <%= listing.description %></li>
        <li>Price: &#8377; <%= listing.price ? Number(listing.price).toLocaleString('en-IN') : 'N/A' %></li>
        <li>Location: <%= listing.location %></li>
        <li>Country: <%= listing.country %></li>
    </ul>
    <a href="/listings/<%= listing._id %>/edit">Edit</a>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display: inline;">
        <button type="submit">Delete</button>
    </form>
</body>
